# Required
ANTHROPIC_API_KEY=your-api-key-here

# AWS / SQS (required for sqs bus mode)
AWS_REGION=us-east-1
SQS_INPUT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/xp-agent-input
SQS_OUTPUT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/xp-agent-output

# Message bus: "stdio" (default) or "sqs"
MESSAGE_BUS=stdio

# Scheduler
SCHEDULE_CRON=0 */6 * * *
SCHEDULE_CONCURRENCY=3
SCHEDULE_MIN_RUNTIME_HOURS=24

# Adapter selection: "sqlite" (default) or "athena"
DATA_SOURCE=sqlite
EXPERIMENT_PLATFORM=growthbook
SQLITE_DATA_SOURCE_PATH=./data/local.db

# Experiment platform
GROWTHBOOK_API_KEY=your-growthbook-key
GROWTHBOOK_API_URL=https://api.growthbook.io

# Data source (Athena — used when DATA_SOURCE=athena)
ATHENA_DATABASE=your_database
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_LOCATION=s3://your-bucket/athena-results/

# Slack (required for slack entry point)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_PORT=3000
